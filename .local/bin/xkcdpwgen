#!/usr/bin/env python3

import argparse
import random

argparser = argparse.ArgumentParser()
argparser.add_argument(
    '--words', '-w', dest='words_path',
    default='/usr/share/dict/words',
    help="Source of words to use")
argparser.add_argument(
    'count', type=int, nargs='?', default=10,
    help="Number of passwords to generate")
argparser.add_argument(
    'wordcount', type=int, nargs='?', default=4,
    help="Number of words in generated passwords")

args = argparser.parse_args()

with open(args.words_path) as words_source:
    words = list(line.strip() for line in words_source)

randomizer = random.SystemRandom()
for count in range(args.count):
    password = tuple(randomizer.choice(words) for _ in range(args.wordcount))
    print(*password)
